app.get('/api/workers/hidden', auth, role('admin', 'manager'), (req, res) => {
  try {
    let query = { role: { $in: ['labour', 'mistry', 'half_mistry'] }, status: 'active', isHidden: true };
    if (req.user.role === 'manager') query.createdBy = req.user._id;
    const workers = User.find(query).map(stripPw);
    res.json({ success: true, data: workers });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.get('/api/workers', auth, role('admin', 'manager'), (req, res) => {
  try {
    let query = { role: { $in: ['labour', 'mistry', 'half_mistry'] }, status: 'active' };
    if (req.user.role === 'manager') query.createdBy = req.user._id;
    const workers = User.find(query).map(stripPw);
    const order = { mistry: 0, labour: 1, half_mistry: 2 };
    workers.sort((a, b) => order[a.role] !== order[b.role] ? order[a.role] - order[b.role] : a.name.localeCompare(b.name));
    res.json({ success: true, data: workers });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.post('/api/workers', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { name, mobile, role: workerRole, rate, photoUrl, forManagerId } = req.body;
    if (!name || !mobile || !workerRole || !rate) return res.status(400).json({ success: false, message: 'All fields required' });
    if (mobile.length !== 10) return res.status(400).json({ success: false, message: 'Mobile must be 10 digits' });
    const existing = User.findOne({ mobile });
    if (existing) return res.status(400).json({ success: false, message: 'Mobile already registered' });
    // Admin can specify which manager this worker belongs to
    const createdBy = (req.user.role === 'admin' && forManagerId) ? forManagerId : req.user._id;
    const worker = User.create({ name, mobile, role: workerRole, rate: Number(rate), photoUrl: photoUrl || null, password: mobile, createdBy, status: 'active' });
    res.json({ success: true, data: stripPw(worker) });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.put('/api/workers/:id/status', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { status, reason } = req.body;
    const prev = User.findById(req.params.id);
    if (!prev) return res.status(404).json({ success: false, message: 'Worker not found' });
    const updates = { status, longLeaveReason: reason || '' };
    if (status === 'disabled') updates.disabledAt = new Date().toISOString();
    User.findByIdAndUpdate(req.params.id, updates);
    ActionLog.create({ performedBy: req.user._id, actionType: 'status_change', targetUser: req.params.id, previousValue: prev.status, newValue: status, date: new Date().toISOString() });
    res.json({ success: true, message: 'Status updated' });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.put('/api/workers/:id/toggle-hidden', auth, role('admin', 'manager'), (req, res) => {
  try {
    const worker = User.findById(req.params.id);
    if (!worker) return res.status(404).json({ success: false, message: 'Worker not found' });
    User.findByIdAndUpdate(req.params.id, { isHidden: !worker.isHidden });
    res.json({ success: true, isHidden: !worker.isHidden });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.get('/api/workers/:id/history', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { month } = req.query;
    if (!month) return res.status(400).json({ success: false, message: 'month required' });
    const [year, m] = month.split('-').map(Number);
    const start = new Date(year, m - 1, 1), end = new Date(year, m, 1);
    const worker = stripPw(User.findById(req.params.id));
    const { attendances, advances, totalDays, totalAdvance, totalTravel } = calcMonthStats(req.params.id, start, end);
    const earned  = worker.rate * totalDays;
    const balance = earned - totalAdvance + totalTravel;
    res.json({ success: true, data: { worker, attendances, advances, totalDays, totalAdvance, totalTravel, earned, balance } });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

// ─────────────── ATTENDANCE ROUTES ───────────────
app.get('/api/attendance/today', auth, role('admin', 'manager'), (req, res) => {
  try {
    const qDate = req.query.date ? toUTCDay(req.query.date) : getToday();
    const qDateEnd = new Date(qDate.getTime() + 86400000);
    let workers;
    if (req.user.role === 'manager') {
      // Manager sees themselves + their workers
      const subordinates = User.find({ role: { $in: ['labour', 'mistry', 'half_mistry'] }, status: 'active', createdBy: req.user._id });
      const self = User.findById(req.user._id);
      workers = (self ? [self, ...subordinates] : subordinates).map(stripPw);
    } else if (req.query.managerId) {
      // Admin viewing a specific manager's screen
      const mgrId = req.query.managerId;
      const subordinates = User.find({ role: { $in: ['labour', 'mistry', 'half_mistry'] }, status: 'active', createdBy: mgrId });
      const mgr = User.findById(mgrId);
      workers = (mgr ? [mgr, ...subordinates] : subordinates).map(stripPw);
    } else {
      // Admin sees all active workers + managers (disabled excluded)
      workers = User.find({ role: { $in: ['labour', 'mistry', 'half_mistry', 'manager'] }, status: 'active' }).map(stripPw);
    }
    const ids = workers.map(w => w._id);
    const atts = Attendance.find({ workerId: { $in: ids }, date: { $gte: qDate, $lt: qDateEnd } });
    const advs = Advance.find({ workerId: { $in: ids }, date: { $gte: qDate, $lt: qDateEnd } });
    const attMap = {}, advMap = {}, advIdMap = {};
    atts.forEach(a => { attMap[a.workerId] = a; });
    advs.forEach(a => { advMap[a.workerId] = (advMap[a.workerId] || 0) + a.amount; advIdMap[a.workerId] = a._id; });
    const result = workers.map(w => ({ ...w, todayAttendance: attMap[w._id] || null, todayAdvance: advMap[w._id] || 0, todayAdvanceId: advIdMap[w._id] || null }));
    const order = { manager: 0, mistry: 1, labour: 2, half_mistry: 3 };
    result.sort((a, b) => ((order[a.role] ?? 9) - (order[b.role] ?? 9)) || a.name.localeCompare(b.name));
    res.json({ success: true, data: result });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.post('/api/attendance/fill-absent', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { date } = req.body;
    const fillDate = date ? toUTCDay(date) : getToday();
    const dayEnd = new Date(fillDate.getTime() + 86400000);
    let workers;
    if (req.user.role === 'manager') {
      const subordinates = User.find({ role: { $in: ['labour', 'mistry', 'half_mistry'] }, status: 'active', createdBy: req.user._id });
      const self = User.findById(req.user._id);
      workers = self ? [self, ...subordinates] : subordinates;
    } else {
      workers = User.find({ status: 'active', role: { $ne: 'admin' } });
    }
    let count = 0;
    for (const w of workers) {
      const exists = Attendance.findOne({ workerId: w._id, date: { $gte: fillDate, $lt: dayEnd } });
      if (!exists) { Attendance.create({ workerId: w._id, date: fillDate.toISOString(), value: '0', markedBy: req.user._id }); count++; }
    }
    res.json({ success: true, count, message: `${count} workers marked absent` });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.put('/api/attendance/travel', auth, (req, res) => {
  try {
    const { date, amount } = req.body;
    const attDate = toUTCDay(date);
    const existing = Attendance.findOne({ workerId: req.user._id, date: { $gte: attDate, $lt: new Date(attDate.getTime() + 86400000) } });
    if (!existing) {
      const att = Attendance.create({ workerId: req.user._id, date: attDate.toISOString(), value: '0', travelExpense: Number(amount) });
      res.json({ success: true, data: att });
    } else {
      const updated = Attendance.findByIdAndUpdate(existing._id, { travelExpense: Number(amount) });
      res.json({ success: true, data: updated });
    }
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

// Manager/admin can edit any worker's travel expense for a specific date
app.put('/api/attendance/travel/:workerId', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { date, amount } = req.body;
    const attDate = toUTCDay(date);
    const existing = Attendance.findOne({ workerId: req.params.workerId, date: { $gte: attDate, $lt: new Date(attDate.getTime() + 86400000) } });
    if (!existing) {
      const att = Attendance.create({ workerId: req.params.workerId, date: attDate.toISOString(), value: '0', travelExpense: Number(amount) });
      res.json({ success: true, data: att });
    } else {
      const updated = Attendance.findByIdAndUpdate(existing._id, { travelExpense: Number(amount) });
      res.json({ success: true, data: updated });
    }
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.get('/api/attendance/me', auth, (req, res) => {
  try {
    const { month } = req.query;
    const [year, m] = month.split('-').map(Number);
    const start = new Date(year, m - 1, 1), end = new Date(year, m, 1);
    const rawAtts  = Attendance.find({ workerId: req.user._id, date: { $gte: start, $lt: end } }, { sort: { date: 1 } });
    const advances = Advance.find(   { workerId: req.user._id, date: { $gte: start, $lt: end } }, { sort: { date: 1 } });
    const worker   = stripPw(User.findById(req.user._id));
    const attendances = rawAtts.map(a => {
      const marker = a.markedBy ? User.findById(a.markedBy) : null;
      return { ...a, markedBy: marker ? { _id: marker._id, name: marker.name } : null };
    });
    const totalDays    = rawAtts.reduce((s, a) => s + parseFloat(a.value || 0), 0);
    const totalAdvance = advances.reduce((s, a) => s + a.amount, 0);
    const totalTravel  = rawAtts.reduce((s, a) => s + (a.travelExpense || 0), 0);
    const earned  = worker.rate * totalDays;
    const balance = earned - totalAdvance + totalTravel;
    res.json({ success: true, data: { attendances, advances, worker, totalDays, totalAdvance, totalTravel, earned, balance } });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.get('/api/attendance/streak/:workerId', auth, role('admin', 'manager'), (req, res) => {
  try {
    const end   = getToday();
    const start = new Date(end); start.setDate(start.getDate() - 6);
    const atts  = Attendance.find({ workerId: req.params.workerId, date: { $gte: start, $lte: end } }, { sort: { date: 1 } });
    res.json({ success: true, data: atts });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

// Managers can also mark their own attendance by passing their own _id as workerId
app.post('/api/attendance', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { workerId, date, value } = req.body;
    const attDate = toUTCDay(date);
    const existing = Attendance.findOne({ workerId, date: { $gte: attDate, $lt: new Date(attDate.getTime() + 86400000) } });
    const prevValue = existing ? existing.value : null;
    let attId;
    if (existing) {
      Attendance.findByIdAndUpdate(existing._id, { value, markedBy: req.user._id });
      attId = existing._id;
    } else {
      const att = Attendance.create({ workerId, date: attDate.toISOString(), value, markedBy: req.user._id });
      attId = att._id;
    }
    const logEntry = ActionLog.create({ performedBy: req.user._id, actionType: 'mark_attendance', targetUser: workerId, previousValue: prevValue, newValue: attId, date: attDate.toISOString() });
    res.json({ success: true, data: { attId, logId: logEntry._id } });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.put('/api/attendance/:id', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { value } = req.body;
    const att = Attendance.findById(req.params.id);
    if (!att) return res.status(404).json({ success: false, message: 'Record not found' });
    const prev = att.value;
    const updated = Attendance.findByIdAndUpdate(req.params.id, { value, markedBy: req.user._id });
    ActionLog.create({ performedBy: req.user._id, actionType: 'edit_attendance', targetUser: att.workerId, previousValue: prev, newValue: value, date: att.date });
    res.json({ success: true, data: updated });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

// ─────────────── ADVANCE ROUTES ───────────────
// Managers can also add advance for themselves by passing their own _id as workerId
app.post('/api/advance', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { workerId, amount, date, note } = req.body;
    if (!workerId || !amount || amount <= 0) return res.status(400).json({ success: false, message: 'Valid worker and amount required' });
    const advDate = date ? toUTCDay(date) : getToday();
    const dayEnd = new Date(advDate.getTime() + 86400000);
    // One advance per day — update existing instead of creating new
    const existing = Advance.findOne({ workerId, date: { $gte: advDate, $lt: dayEnd } });
    let advance;
    if (existing) {
      advance = Advance.findByIdAndUpdate(existing._id, { amount: Number(amount), givenBy: req.user._id, note: note || '' });
    } else {
      advance = Advance.create({ workerId, amount: Number(amount), date: advDate.toISOString(), givenBy: req.user._id, note: note || '' });
      ActionLog.create({ performedBy: req.user._id, actionType: 'add_advance', targetUser: workerId, previousValue: null, newValue: advance._id, date: new Date().toISOString() });
    }
    res.json({ success: true, data: advance });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.put('/api/advance/:id', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { amount } = req.body;
    if (!amount || Number(amount) <= 0) return res.status(400).json({ success: false, message: 'Valid amount required' });
    const advance = Advance.findById(req.params.id);
    if (!advance) return res.status(404).json({ success: false, message: 'Advance not found' });
    const updated = Advance.findByIdAndUpdate(req.params.id, { amount: Number(amount), givenBy: req.user._id });
    res.json({ success: true, data: updated });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.delete('/api/advance/:id', auth, role('admin', 'manager'), (req, res) => {
  try {
    const advance = Advance.findByIdAndDelete(req.params.id);
    if (!advance) return res.status(404).json({ success: false, message: 'Advance not found' });
    ActionLog.create({ performedBy: req.user._id, actionType: 'remove_advance', targetUser: advance.workerId, previousValue: advance.amount, newValue: null, date: new Date().toISOString() });
    res.json({ success: true, message: 'Advance removed' });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

// ─────────────── ACTION LOG / UNDO ───────────────
app.get('/api/actions/log', auth, role('admin', 'manager'), (req, res) => {
  try {
    const since = new Date(Date.now() - 30 * 60 * 1000);
    let logs = ActionLog.find({ performedBy: req.user._id, createdAt: { $gte: since } }, { sort: { createdAt: -1 }, limit: 10 });
    logs = logs.map(l => {
      const targetUser = l.targetUser ? User.findById(l.targetUser) : null;
      return { ...l, targetUser: targetUser ? { _id: targetUser._id, name: targetUser.name } : null };
    });
    res.json({ success: true, data: logs });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

app.post('/api/actions/undo', auth, role('admin', 'manager'), (req, res) => {
  try {
    const { actionId } = req.body;
    const log = ActionLog.findById(actionId);
    if (!log) return res.status(404).json({ success: false, message: 'Action not found' });
    const since = new Date(Date.now() - 30 * 60 * 1000);
    if (new Date(log.createdAt) < since) return res.status(400).json({ success: false, message: 'Undo window has expired (30 min)' });

    if (log.actionType === 'mark_attendance') {
      if (log.previousValue === null) Attendance.findByIdAndDelete(log.newValue);
      else Attendance.findByIdAndUpdate(log.newValue, { value: log.previousValue });
    } else if (log.actionType === 'add_advance') {
      Advance.findByIdAndDelete(log.newValue);
    } else if (log.actionType === 'status_change') {
      User.findByIdAndUpdate(log.targetUser, { status: log.previousValue });
    }

    ActionLog.findByIdAndDelete(actionId);
    res.json({ success: true, message: 'Action undone successfully' });
  } catch (e) { res.status(500).json({ success: false, message: e.message }); }
});

// ─────────────── CRON — AUTO ABSENT 23:59 IST (18:29 UTC) ───────────────
cron.schedule('29 18 * * *', () => {
  console.log('[CRON] Running auto-absent job...');
  try {
    const today   = getToday();
    const workers = User.find({ status: 'active', role: { $ne: 'admin' } });
    let count = 0;
    for (const w of workers) {
      const exists = Attendance.findOne({ workerId: w._id, date: { $gte: today, $lt: new Date(today.getTime() + 86400000) } });
      if (!exists) { Attendance.create({ workerId: w._id, date: today.toISOString(), value: '0', markedBy: null }); count++; }
    }
    console.log(`[CRON] Auto-absent applied to ${count} workers`);
  } catch (e) { console.error('[CRON] Error:', e.message); }
}, { timezone: 'UTC' });

// ─────────────── SEED + START ───────────────
function seedAdmin() {
  try {
    const exists = User.findOne({ mobile: process.env.ADMIN_MOBILE });
    if (!exists) {
      User.create({ name: 'Admin', mobile: process.env.ADMIN_MOBILE, role: 'admin', password: process.env.ADMIN_PASSWORD, status: 'active' });
      console.log('[SEED] Admin user created:', process.env.ADMIN_MOBILE);
    } else {
      console.log('[SEED] Admin already exists');
    }
  } catch (e) { console.error('[SEED] Error:', e.message); }
}

seedAdmin();
const server = app.listen(process.env.PORT || 5000, '0.0.0.0', () => {
  console.log(`[SERVER] Running on port ${process.env.PORT || 5000}`);
});
server.on('error', (e) => { console.error('[SERVER] Error:', e.message); process.exit(1); });

// Graceful shutdown so nodemon restarts work cleanly on Windows
const shutdown = () => server.close(() => process.exit(0));
process.on('SIGTERM', shutdown);
process.on('SIGINT', shutdown);

